# Copia este archivo a .env.local y rellena con tus claves de Supabase.
# .env.local está gitignoreado — nunca se sube.

# Públicas (seguras en el cliente):
NEXT_PUBLIC_SUPABASE_URL=https://sihmvzmjgmtkoojruazn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# SOLO servidor — SECRETAS. La service_role salta RLS: nunca en el cliente ni en git.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
ADMIN_PASSCODE=change-me
